{
	"compilerOptions": {
		"target": "ESNext",
		"module": "node16",
		"moduleResolution": "node16",
		"rootDir": "./src",
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
